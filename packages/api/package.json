{
	"name": "api",
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./src/index.ts"
		},
		"./app": "./src/app.ts"
	},
	"scripts": {
		"dev": "wrangler dev --port 8788",
		"dev:bun": "bun --watch src/server.ts",
		"dev:cf": "wrangler dev --port 8788",
		"start": "bun src/server.ts",
		"seed:landlord": "bun src/scripts/seed-landlord.ts",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"db-generate": "drizzle-kit generate --config=drizzle.cf.config.ts",
		"db-generate:bun": "drizzle-kit generate",
		"db-migrate": "wrangler d1 migrations apply DB --local",
		"db-migrate:bun": "drizzle-kit migrate",
		"db-migrate:cf:local": "wrangler d1 migrations apply DB --local",
		"db-push": "drizzle-kit push",
		"test": "NODE_ENV=test bun test"
	},
	"dependencies": {
		"hono": "^4.12.9",
		"drizzle-orm": "^0.45.1",
		"@libsql/client": "^0.17.2",
		"zod": "^4.3.6",
		"pino": "^10.3.1"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"@types/node": "^22",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"wrangler": "^4.4.0"
	}
}
