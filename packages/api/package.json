{
	"name": "api",
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./src/index.ts"
		},
		"./app": "./src/app.ts"
	},
	"scripts": {
		"dev": "wrangler dev --port 8788",
		"seed:landlord": "bun src/scripts/seed-landlord.ts",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply DB --local",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"hono": "^4.12.9",
		"drizzle-orm": "^0.45.1",
		"zod": "^4.3.6",
		"pino": "^10.3.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.14.1",
		"@types/bun": "^1.3.11",
		"@types/node": "^22",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^13.1.3",
		"vitest": "^4.1.2",
		"wrangler": "^4.80.0"
	}
}
