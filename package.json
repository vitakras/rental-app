		"react-router": "7.13.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@react-router/dev": "7.13.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/node": "^22",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4.2.2",
