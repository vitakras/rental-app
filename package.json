{
	"name": "rental-app",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter web build",
		"dev": "bun run --parallel --workspaces dev",
		"start": "bun run --filter web start",
		"typecheck": "bun run --filter web typecheck",
		"db-generate": "bun run --filter web db-generate",
		"db-migrate": "bun run --filter web db-migrate",
		"db-push": "bun run --filter web db-push",
		"test": "bun run --filter web test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9"
	}
}
